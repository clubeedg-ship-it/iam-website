# IAM deploy sudoers drop-in — installed at /etc/sudoers.d/iam-deploy by bootstrap.sh.
# Implements D-09 from M2-03-cicd: narrowly-scoped NOPASSWD for the deploy user.
# File must be mode 440 and owned by root:root; visudo -cf validates before install.
#
# Allow `deploy` to run iam-deploy as the `iam` user without password:
deploy ALL=(iam)  NOPASSWD: /usr/local/bin/iam-deploy *
#
# Allow `deploy` to reload (but not start/stop/mask) the two services and nginx:
deploy ALL=(root) NOPASSWD: /bin/systemctl reload iam-api, /bin/systemctl reload iam-api-staging, /bin/systemctl reload nginx, /bin/systemctl restart iam-api, /bin/systemctl restart iam-api-staging
